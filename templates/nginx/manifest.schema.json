{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vps-kit-mcp.local/templates/nginx/manifest.schema.json",
  "title": "Nginx Template Manifest",
  "type": "object",
  "required": ["version", "templates", "default_combos"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "snippet_file"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "name": { "type": "string", "minLength": 1 },
          "snippet_file": { "type": "string", "pattern": "^snippets/.+\\.conf\\.tpl$" },
          "single": { "type": "boolean" },
          "requires": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
          },
          "conflicts": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z0-9_]+$" }
          }
        },
        "additionalProperties": true
      }
    },
    "default_combos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "templates"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
          "name": { "type": "string", "minLength": 1 },
          "templates": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
