{
  "version": 1,
  "templates": [
    {
      "id": "security_headers",
      "name": "安全响应头基线",
      "snippet_file": "snippets/security_headers.conf.tpl",
      "single": true,
      "min_nginx_version": "1.7.5"
    },
    {
      "id": "hsts",
      "name": "HSTS 严格 HTTPS",
      "snippet_file": "snippets/hsts.conf.tpl",
      "single": true,
      "requires": ["security_headers"],
      "vars": {
        "HSTS_MAX_AGE": {
          "default": "31536000",
          "pattern": "^[0-9]+$"
        }
      }
    },
    {
      "id": "reverse_proxy_enhanced",
      "name": "反代增强（超时/转发头）",
      "snippet_file": "snippets/reverse_proxy_enhanced.conf.tpl",
      "single": true
    },
    {
      "id": "wordpress_basic",
      "name": "WordPress 基础优化",
      "snippet_file": "snippets/wordpress_basic.conf.tpl",
      "single": true
    }
  ],
  "default_combos": [
    {
      "id": "general_reverse_proxy",
      "name": "通用反代",
      "templates": ["security_headers", "reverse_proxy_enhanced"]
    },
    {
      "id": "https_production",
      "name": "HTTPS生产",
      "templates": ["security_headers", "hsts"]
    },
    {
      "id": "wordpress_common",
      "name": "WordPress常用",
      "templates": ["wordpress_basic", "security_headers"]
    },
    {
      "id": "long_connection_service",
      "name": "长连接服务",
      "templates": ["reverse_proxy_enhanced", "security_headers"]
    }
  ]
}
